---
const projects = [
  {
    icon: '🛒',
    gradient: 'from-blue-500 to-purple-500',
    title: '쇼핑몰 웹앱',
    status: { label: '완료', color: 'bg-green-500/20 text-green-400 border-green-500/30' },
    desc: 'React와 Node.js로 만든 풀스택 쇼핑몰. 장바구니, 결제 기능, 관리자 대시보드를 포함합니다.',
    tags: [
      { label: 'React',   cls: 'bg-blue-500/10 text-blue-400 border-blue-500/20'   },
      { label: 'Node.js', cls: 'bg-green-500/10 text-green-400 border-green-500/20' },
      { label: 'MongoDB', cls: 'bg-purple-500/10 text-purple-400 border-purple-500/20' },
    ],
    github: '#',
    demo: '#',
    delay: 0,
  },
  {
    icon: '📝',
    gradient: 'from-purple-500 to-green-400',
    title: '할 일 관리앱',
    status: { label: '진행중', color: 'bg-blue-500/20 text-blue-400 border-blue-500/30' },
    desc: '드래그앤드롭 기능을 갖춘 Todo 앱. 카테고리별 관리, 마감일 알림, 다크모드를 지원합니다.',
    tags: [
      { label: 'JavaScript',   cls: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20' },
      { label: 'Tailwind',     cls: 'bg-teal-500/10 text-teal-400 border-teal-500/20'       },
      { label: 'LocalStorage', cls: 'bg-orange-500/10 text-orange-400 border-orange-500/20' },
    ],
    github: '#',
    demo: '#',
    delay: 150,
  },
  {
    icon: '🌤️',
    gradient: 'from-green-400 to-cyan-500',
    title: '날씨 대시보드',
    status: { label: '완료', color: 'bg-green-500/20 text-green-400 border-green-500/30' },
    desc: 'OpenWeather API를 활용한 실시간 날씨 앱. 5일 예보, 지도 연동, 위치 자동 감지를 제공합니다.',
    tags: [
      { label: 'TypeScript', cls: 'bg-blue-400/10 text-blue-300 border-blue-400/20'  },
      { label: 'React',      cls: 'bg-cyan-500/10 text-cyan-400 border-cyan-500/20'  },
      { label: 'API',        cls: 'bg-green-500/10 text-green-400 border-green-500/20' },
    ],
    github: '#',
    demo: '#',
    delay: 300,
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16 fade-in">
      <div class="section-divider"></div>
      <h2 class="text-3xl md:text-4xl font-bold">Projects</h2>
      <p class="text-slate-500 mt-2 text-sm">직접 만든 프로젝트들</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {projects.map(p => (
        <div class="project-card rounded-2xl p-6 fade-in" data-delay={p.delay}>
          <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${p.gradient} flex items-center justify-center text-2xl mb-5`}>
            {p.icon}
          </div>
          <div class="flex items-center gap-2 mb-3">
            <h3 class="text-lg font-bold text-white">{p.title}</h3>
            <span class={`text-xs px-2 py-0.5 rounded-full border ${p.status.color}`}>{p.status.label}</span>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-5">{p.desc}</p>
          <div class="flex flex-wrap gap-2 mb-5">
            {p.tags.map(t => (
              <span class={`text-xs px-2.5 py-1 rounded-full border ${t.cls}`}>{t.label}</span>
            ))}
          </div>
          <div class="flex gap-3 pt-4 border-t border-white/5">
            <a href={p.github} class="flex-1 text-center text-xs font-semibold py-2 rounded-lg bg-white/5 hover:bg-blue-500/20 text-slate-300 hover:text-blue-400 transition-all">GitHub</a>
            <a href={p.demo}   class="flex-1 text-center text-xs font-semibold py-2 rounded-lg bg-white/5 hover:bg-purple-500/20 text-slate-300 hover:text-purple-400 transition-all">Live Demo</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
