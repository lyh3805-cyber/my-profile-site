---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 py-16 px-6 text-center">
  <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="text-lg font-bold gradient-text">&lt;이코딩 /&gt;</span>
    <p class="text-slate-600 text-sm">
      © {year} 이코딩. Made with ❤️ &amp; Astro + Tailwind
    </p>
    <div class="flex gap-4">
      <a
        href="mailto:leecoding@example.com"
        class="text-slate-600 hover:text-blue-400 text-sm transition-colors">Email</a
      >
      <a
        href="https://github.com/leecoding"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-600 hover:text-purple-400 text-sm transition-colors">GitHub</a
      >
      <a href="/blog" class="text-slate-600 hover:text-green-400 text-sm transition-colors">Blog</a>
    </div>
  </div>
</footer>
