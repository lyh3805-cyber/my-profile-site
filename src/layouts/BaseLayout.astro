---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = '이코딩 | 개발자 포트폴리오',
  description = '웹 개발에 열정을 가진 개발자 이코딩의 포트폴리오',
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-[#1a1730] text-slate-200 antialiased">
    <slot />
  </body>
</html>
